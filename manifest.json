{
  "id": "com.raheeqnadeem.colorblindguide",
  "name": "Color Blind Guide",
  "version": "1.1.0",
  "manifestVersion": 6,
  "main": "panel.html",
  "host": [
    { "app": "PS", "minVersion": "26.0.0" },
    { "app": "ILST", "minVersion": "28.0.0" }
  ],
  "icons": [
    { "width": 48, "height": 48, "path": "assets/icons/icon.svg" }
  ],
  "entrypoints": [{
    "type": "panel",
    "id": "mainPanel",
    "label": { "default": "Color Blind Guide" },
    "minimumSize": { "width": 200, "height": 400 },
    "maximumSize": { "width": 800, "height": 2000 },
    "preferredDockedSize": { "width": 250, "height": 500 },
    "preferredFloatingSize": { "width": 250, "height": 500 }
  }],
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "permissions": {
    "allow": ["enable-devtools"],
    "allowCodeGenerationFromStrings": true,
    "localFileSystem": "readAndWrite"
  }
}
